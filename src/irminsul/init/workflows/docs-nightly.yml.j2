name: docs-nightly

# Configured deterministic warnings run nightly. Switch the profile to
# `advisory` when LLM checks are configured and should run on this schedule.

on:
  schedule:
    - cron: "23 6 * * *"   # daily at 06:23 UTC
  workflow_dispatch:

jobs:
  audit:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
{% if code_repo_spec %}
      - uses: actions/checkout@v4
        with:
          repository: {{ code_repo_spec }}
          path: {{ code_subfolder }}
          fetch-depth: 1
{% endif %}
      - uses: {{ github_user }}/irminsul@v0.1.0
        with:
          profile: configured
