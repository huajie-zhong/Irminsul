project_name = "{{ project_name }}"

[paths]
docs_root = "docs"
source_roots = {{ source_roots | tojson }}

[checks]
hard = [
    "frontmatter",
    "globs",
    "uniqueness",
    "links",
    "schema-leak",
    "coverage",
    "liar",
    "prose-file-reference",
    "rfc-lifecycle-integrity",
]
soft_deterministic = [
    "mtime-drift",
    "stale-reaper",
    "orphans",
    "supersession",
    "parent-child",
    "glossary-discipline",
    "external-links",
    "reality",
    "boundary",
    "phantom-layer",
    "requires-env",
    "import-deps",
    "terminology-overload",
    "claim-provenance",
    "inventory-drift",
    "doc-refs",
]

[checks.schema_leak]
protected_paths = ["docs/20-components/**/*.md"]

[checks.external_links]
enabled = false
timeout_seconds = 5.0
cache_path = ".irminsul-cache/external-links.json"
ttl_hours = 168

[checks.stale_reaper]
deprecated_threshold_days = 180

[checks.glossary_discipline]
glossary_path = "docs/GLOSSARY.md"

[checks.parent_child]
length_warning_lines = 300

# terminology-overload ships with no rules; add [[checks.terminology_overload.rules]]
# entries for terms that mean different things in different parts of your project.

[overrides]
mtime_drift_days = 30

[languages]
enabled = {{ languages | tojson }}
