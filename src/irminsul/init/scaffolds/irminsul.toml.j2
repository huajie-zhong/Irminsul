project_name = "{{ project_name }}"

[paths]
docs_root = "docs"
source_roots = {{ source_roots | tojson }}

[languages]
enabled = {{ languages | tojson }}

{% if "typescript" in languages -%}
[regen.typescript]
enabled = true
tsconfig = "tsconfig.json"
out_dir = "docs/40-reference/typescript"

{% endif -%}

[render]
target = "{{ render_target }}"
site_dir = "site"
